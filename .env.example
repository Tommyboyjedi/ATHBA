# Django
DJANGO_SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# API base URL for frontend or integrations (if used)
API_BASE_URL=http://localhost:8010

# Mongo (strict auth)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB_NAME=ai_platform
MONGO_USER=your-username
MONGO_PASS=your-password

# LLM service
LLM_SERVER_URL=http://127.0.0.1:8011
LLM_STATUS_INTERVAL=10
LLM_MODEL_TTL=120

# RD thresholds
RD_MEM_THRESHOLD=0.95
RD_CPU_THRESHOLD=1
# Environment variables for OpenAI provider
OPENAI_API_KEY=
OPENAI_ORG=
OPENAI_PROJECT=
OPENAI_API_BASE=

# Environment variables for Anthropic/Claude provider (REQUIRED for Architect agent)
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com/v1
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4.5-20250514

# LLM Service Configuration
LLM_SERVER_URL=http://127.0.0.1:8011

# CPU-only mode (set to true to disable GPU acceleration)
# Useful for testing on systems without dedicated GPU
# When enabled, only basic models run on CPU and Claude is used for complex tasks
CPU_ONLY=false
